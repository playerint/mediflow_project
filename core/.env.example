# ─────────────────────────────────────────────────────────────
# MEDIFLOW Core — 환경 변수 예시
# 이 파일을 복사해 .env 로 저장하고 실제 값을 채운다.
# .env 는 절대 git에 올리지 않는다 (.gitignore 에 포함됨).
# ─────────────────────────────────────────────────────────────

# 플랫폼 DB (병원 정보 · 운영 데이터)
DB_PLATFORM_URL=jdbc:postgresql://localhost:5432/mediflow_platform
DB_PLATFORM_USERNAME=mediflow
DB_PLATFORM_PASSWORD=your_db_password_here

# JWT 시크릿 (최소 256비트 이상 랜덤 문자열 권장)
JWT_SECRET=your_jwt_secret_here

# AI 서비스 (Python FastAPI) URL
AI_SERVICE_URL=http://localhost:8000

# 서버 포트
PORT=8080
