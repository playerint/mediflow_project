# ─────────────────────────────────────────────────────────────
# MEDIFLOW AI Service — 환경 변수 예시
# 이 파일을 복사해 .env 로 저장하고 실제 값을 채운다.
# .env 는 절대 git에 올리지 않는다 (.gitignore 에 포함됨).
# ─────────────────────────────────────────────────────────────

# AI 제공자 (gemini 또는 openai)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# 벡터 DB (pgvector) 연결 정보
VECTOR_DB_URL=postgresql://mediflow:password@localhost:5432/mediflow_vector

# 서버 포트
PORT=8000

# CORS 허용 오리진 (Spring Boot core 서비스)
ALLOWED_ORIGINS=http://localhost:8080
